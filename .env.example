# Conexão com o PostgreSQL (Supabase)
DATABASE_URL=postgresql://user:password@host:5432/postgres
PORT=3030

# Auth / JWT — gere um segredo forte: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=troque-por-um-segredo-forte
JWT_EXPIRES_IN=8h

# Origens permitidas para CORS (separadas por vírgula)
CORS_ORIGIN=http://localhost:3000

# Super admin de bootstrap (criado pela migration CreateAuthTables)
SUPERADMIN_EMAIL=admin@exemplo.com
SUPERADMIN_PASSWORD=troque-esta-senha
